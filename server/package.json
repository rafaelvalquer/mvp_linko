{
  "name": "mvp-paylink-server",
  "type": "module",
  "version": "0.1.0",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch run-with-role.js all ./server.js",
    "dev:web": "node --watch run-with-role.js web ./server.js",
    "dev:worker": "node --watch run-with-role.js worker ./worker.js",
    "start": "node run-with-role.js web ./server.js",
    "start:web": "node run-with-role.js web ./server.js",
    "start:worker": "node run-with-role.js worker ./worker.js",
    "test": "node test/run-tests.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.2",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "resend": "^6.9.2",
    "stripe": "^20.3.1"
  }
}
